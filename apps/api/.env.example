PROJECT_NAME="Calorie Tracker API"
VERSION="1.0.0"
API_V1_STR="/api/v1"
ENVIRONMENT="development"

# SQLite local default
SQLALCHEMY_DATABASE_URI="sqlite:///./calorie_tracker.db"

# PostgreSQL example
# SQLALCHEMY_DATABASE_URI="postgresql+psycopg://postgres:postgres@localhost:5432/zoro"

SECRET_KEY="replace-this-with-a-long-random-secret"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080

BACKEND_CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
BACKEND_CORS_ORIGIN_REGEX="^https?://(localhost|127\\.0\\.0\\.1|0\\.0\\.0\\.0|192\\.168\\.\\d+\\.\\d+)(:\\d+)?$"

GEMINI_API_KEY=""
GEMINI_MODEL_NAME="gemini-2.0-flash"
AI_CHAT_RATE_LIMIT_COUNT=20
AI_CHAT_RATE_LIMIT_WINDOW_SECONDS=300
AI_MEAL_PARSE_RATE_LIMIT_COUNT=15
AI_MEAL_PARSE_RATE_LIMIT_WINDOW_SECONDS=300
